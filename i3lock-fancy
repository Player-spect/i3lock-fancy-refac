# ─── Ayuda ───────────────────────────────────────────────────────────────────

show_help() {
    cat <<EOF
Usage: ${0##*/} [options]

Options:
    -h, --help       This help menu.
    -d, --desktop    Attempt to minimize all windows before locking.
    -g, --greyscale  Set background to greyscale instead of color.
    -p, --pixelate   Pixelate the background instead of blur, runs faster.
    -f <fontname>, --font <fontname>  Set a custom font.
    -t <text>, --text <text>          Set a custom text prompt.
    -l, --listfonts  Display a list of possible fonts and exit.
    -n, --nofork     Do not fork i3lock after starting.
    --               Must be last option. Set command to use for taking a
                     screenshot. Default is 'import -window root'.
EOF
    exit 1
}

# ─── Parseo de argumentos ────────────────────────────────────────────────────

list_fonts() {
    magick -list font | awk -F: '/Font: / { print $2 }' | sort -du | command -- "${PAGER:-less}"
    exit 0
}

parse_args() {
    local temp
    temp="$(getopt -o :hdnpglt:f: -l desktop,help,listfonts,nofork,pixelate,greyscale,text:,font: --name "$0" -- "$@")"
    eval set -- "$temp"

    while true; do
        case "$1" in
            -h|--help)      show_help ;;
            -d|--desktop)   desktop=$(command -V wmctrl) ; shift ;;
            -g|--greyscale) hue=(-level "0%,100%,0.6" -set colorspace Gray -average) ; shift ;;
            -p|--pixelate)  effect=(-scale 10% -scale 1000%) ; shift ;;
            -f|--font)      [[ -n "${2:-}" ]] && font="$2" ; shift 2 ;;
            -t|--text)      text="$2" ; shift 2 ;;
            -l|--listfonts) list_fonts ;;
            -n|--nofork)    i3lock_cmd+=(--nofork) ; shift ;;
            --) shift ; shot_custom=true ; [[ $# -gt 0 ]] && shot=("$@") ; break ;;
            *)  echo "Error: opción desconocida '$1'" >&2 ; exit 1 ;;
        esac
    done
}

# ─── Captura de pantalla ─────────────────────────────────────────────────────

take_screenshot() {
    command -- "${shot[@]}" "$image"
}

# ─── Detección de brillo y tema ──────────────────────────────────────────────

detect_theme() {
    local value=60
    local color

    color=$(magick "$image" -gravity center -crop 100x100+0+0 +repage -colorspace hsb \
        -resize 1x1 txt:- | awk -F '[%$]' 'NR==2{gsub(",",""); printf "%.0f\n", $(NF-1)}')

    bw="white"
    icon="/usr/share/i3lock-fancy/icons/lock.png"
    param=("--inside-color=ffffff1c" "--ring-color=ffffff3e" \
        "--line-color=ffffff00" "--keyhl-color=00000080" "--ringver-color=00000000" \
        "--separator-color=22222260" "--insidever-color=0000001c" \
        "--ringwrong-color=00000055" "--insidewrong-color=0000001c" \
        "--verif-color=00000000" "--wrong-color=ff000000" "--time-color=00000000" \
        "--date-color=00000000" "--layout-color=00000000")
}



# ─── Composición de la imagen ────────────────────────────────────────────────

compose_image() {
    magick "$image" "${hue[@]}" "${effect[@]}" -gravity center\
        -font "$font_time" -fill "$color_time" -pointsize 250 -annotate +958-400 "$time" \
        -font "$font"      -fill "$bw"         -pointsize 26  -annotate +958+270 "$text" \
        "$icon" -gravity center -geometry +958+0 -composite "$image"

}


# ─── Bloqueo de pantalla ─────────────────────────────────────────────────────

run_lock() {
    ${desktop} ${desktop:+-k on}

    if ! "${i3lock_cmd[@]}" "${param[@]}" >/dev/null 2>&1; then
        "${i3lock_cmd[@]}"
    fi

    ${desktop} ${desktop:+-k off}
}

# ─── Main ────────────────────────────────────────────────────────────────────

main() {
    init_config
#    echo "1"
    detect_locale_text
#    echo "2"
    trap 'rm -f "$image"' EXIT
#    echo "3"
    parse_args "$@"
#    echo "4"
    take_screenshot
#    echo "5"
    detect_theme
#    echo "6"
    compose_image
#    echo "7"
    run_lock
#   echo "9"
}

main "$@"
